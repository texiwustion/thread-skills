THREAD_ADVANCE_STOP_ON_DIRTY_INTERRUPT=true
THREAD_ADVANCE_STOP_ON_PENDING_PROPOSAL=true
THREAD_BOOTSTRAP_ID_STYLE=slug-tNN
THREAD_BOOTSTRAP_AUTO_CHECKOUT=true
THREAD_BOOTSTRAP_TEMPLATE_ROOT=threads/_template
THREAD_PUBLISH_GITHUB_VISIBILITY=public
